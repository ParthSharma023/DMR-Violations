  },
  {
    "TableName": "DATATBL",
    "Name": "Color Format for Flow % difference from Rolling 3 Months Minimum max per DATESTAMP",
    "Expression": "\nVAR __BASELINE_VALUE = [Rolling 3 Months Minimum max per DATESTAMP]\nVAR __VALUE_TO_COMPARE = SUM('DATATBL'[Color Format for Flow])\nRETURN\n\tIF(\n\t\tNOT ISBLANK(__VALUE_TO_COMPARE),\n\t\tDIVIDE(__VALUE_TO_COMPARE - __BASELINE_VALUE, __BASELINE_VALUE)\n\t)",
    "DisplayFolder": null,
    "Description": null
  },
  {
    "TableName": "DATATBL",
    "Name": "Rolling 3 Months Minimum max per DATESTAMP divided by Color Format for Flow",
    "Expression": "\nDIVIDE(\n\t[Rolling 3 Months Minimum max per DATESTAMP],\n\tAVERAGE('DATATBL'[Color Format for Flow])\n) ",
    "DisplayFolder": null,
    "Description": null
  },
  {
