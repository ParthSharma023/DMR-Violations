  {
    "TableName": "DATATBL",
    "Name": "Rolling 3 Months Minimum max per DATESTAMP",
    "Expression": "\nMAXX(\n\tKEEPFILTERS(VALUES('DATATBL'[DATESTAMP])),\n\tCALCULATE([Rolling 3 Months Minimum])\n)",
    "DisplayFolder": null,
