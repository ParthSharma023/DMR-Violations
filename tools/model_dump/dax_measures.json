  {
    "TableName": "DATATBL",
    "Name": "Measure1",
    "Expression": "\nVar Maxvale =\nUNION(\n    ROW(\"Value\",SELECTEDVALUE(DATATBL[CURVALUE])),\n    Row(\"Value\",[Rolling 3 Months Minimum])\n)\nreturn \nMINX(Maxvale,[Value])",
